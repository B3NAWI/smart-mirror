HALO_VOICE_IDLE_TIMEOUT_SECONDS=30
HALO_VOICE_SESSION_TIMEOUT_SECONDS=300
DATABASE_URL=sqlite:///data/halo_mirror.db
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
