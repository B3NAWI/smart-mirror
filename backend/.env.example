OPENAI_API_KEY=your_openai_api_key_here
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=mirror/sensors

API_HOST=0.0.0.0
API_PORT=5000
HALO_API_KEY=change_me_generate_secure_key
HALO_DEV_API_KEY=halo-local-dev-key
OPENAI_REALTIME_MODEL=gpt-realtime-2
